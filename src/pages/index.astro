---
import Layout from '../layouts/Layout.astro';
import GameCard from '../components/GameCard.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { data: juegos, error } = await supabase.from('Games').select('*');
---

<Layout title="DARLIOSHOP | Catálogo">
    <section class="grid-juegos">
        {juegos && juegos.map((juego) => (
            <GameCard {...juego} />
        ))}
    </section>
</Layout>

<style>
  .grid-juegos {
    display: grid;
    /* Esto ajusta el número de columnas según el tamaño de la pantalla */
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); 
    gap: 2rem;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 0;
  }
</style>
