---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { slug } = Astro.params;

// 1. Traemos la info del juego usando la nueva columna lemon_checkout_url
const { data: juego, error } = await supabase
  .from('Games')
  .select('*')
  .eq('slug', slug)
  .single();

if (error || !juego) {
  return Astro.redirect('/404');
}

// 2. Lógica de Stock Real
const { count: stockActual } = await supabase
  .from('keys_inventory')
  .select('*', { count: 'exact', head: true })
  .eq('game_id', juego.id)
  .eq('is_sold', false);

const hayStock = (stockActual ?? 0) > 0;
---

<Layout title={`Wiki | ${juego.title}`}>
  <div class="wiki-container">
    <div class="main-content">
      <div class="sidebar">
        <div class="poster-area">
          <img src={juego.img_url} alt={juego.title} />
        </div>
        
        <div class="purchase-row">
          <div class="price-box">
            ${juego.price ? juego.price.toFixed(2) : "0.00"}
          </div>

          {hayStock ? (
            <button 
              class="buy-button" 
              id="buy-button"
              data-lemon-url={juego.lemon_checkout_url} 
            >
              COMPRAR KEY
            </button>
          ) : (
            <button class="buy-button" disabled>AGOTADO</button>
          )}
        </div>
        
        {hayStock && <p class="stock-tag">¡Stock disponible!</p>}
      </div>

      <div class="details-area">
        <h1 class="game-title">{juego.title}</h1>
        <div class="description-text">
          <p>{juego.description || "Este título aún no cuenta con una descripción oficial."}</p>
        </div>
      </div>
    </div>

    {juego.video_id && (
      <div class="trailer-section">
        <h2 class="section-label">TRAILER OFICIAL</h2>
        <div class="trailer-container">
          <iframe 
            src={`https://www.youtube.com/embed/${juego.video_id}`}
            title="YouTube video player" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen>
          </iframe>
        </div>
      </div>
    )}
  </div>
</Layout>

<script src="https://app.lemonsqueezy.com/js/lemon.js" defer></script>

<script is:inline>
  function initLemon() {
    const buyButton = document.getElementById('buy-button');
    
    if (buyButton) {
      buyButton.addEventListener('click', (e) => {
        e.preventDefault();
        const checkoutUrl = buyButton.getAttribute('data-lemon-url');
        
        if (!checkoutUrl || checkoutUrl === "NULL") {
          alert("Error: No se encontró el enlace de Lemon Squeezy para este juego.");
          return;
        }

        // Abre el modal de Lemon Squeezy directamente
        if (typeof LemonSqueezy !== 'undefined') {
          LemonSqueezy.Url.Open(checkoutUrl);
        } else {
          // Fallback en caso de que el script no haya cargado
          window.location.href = checkoutUrl;
        }
      });
    }
  }

  // Ejecutar cuando el script y la página estén listos
  window.addEventListener('load', initLemon);
</script>

<style>
  /* Se mantiene tu estilo original que está excelente */
  .wiki-container { max-width: 1100px; margin: 3rem auto; padding: 0 1rem; display: flex; flex-direction: column; gap: 4rem; color: white; font-family: 'Inter', sans-serif; }
  .main-content { display: grid; grid-template-columns: 320px 1fr; gap: 3rem; align-items: start; }
  .poster-area img { width: 100%; border-radius: 15px; border: 3px solid #7c4dff; box-shadow: 0 0 25px rgba(124, 77, 255, 0.4); transition: transform 0.3s ease; }
  .poster-area img:hover { transform: scale(1.02); box-shadow: 0 0 40px rgba(124, 77, 255, 0.6); }
  .purchase-row { display: flex; gap: 0.8rem; margin-top: 1.5rem; }
  .price-box { flex: 1; border: 2px solid #2de29d; color: #2de29d; text-align: center; padding: 0.8rem; border-radius: 10px; font-size: 1.2rem; font-weight: 800; }
  .buy-button { flex: 2; background: #5e35b1; color: white; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; text-transform: uppercase; transition: 0.3s; padding: 0.8rem; }
  .buy-button:hover:not(:disabled) { background: #7c4dff; transform: translateY(-3px); }
  .buy-button:disabled { background: #4a5568 !important; color: #a0aec0 !important; cursor: not-allowed; opacity: 0.7; border: 1px solid #2d3748; transform: none !important; }
  .stock-tag { color: #2de29d; font-size: 0.8rem; margin-top: 0.5rem; text-align: center; font-weight: bold; }
  .game-title { font-size: 3.5rem; margin: 0 0 1.5rem 0; font-weight: 900; line-height: 1; }
  .description-text { font-size: 1.1rem; line-height: 1.8; color: #cbd5e1; text-align: justify; }
  .section-label { font-size: 0.9rem; margin-bottom: 1.5rem; color: #7c4dff; font-weight: bold; }
  .trailer-container { width: 100%; aspect-ratio: 16 / 9; border-radius: 20px; overflow: hidden; border: 2px solid rgba(124, 77, 255, 0.3); }
  .trailer-container iframe { width: 100%; height: 100%; }
  @media (max-width: 850px) { .main-content { grid-template-columns: 1fr; } .sidebar { max-width: 320px; margin: 0 auto; } .game-title { text-align: center; font-size: 2.5rem; } }
</style>