---
// Cambiamos checkout_url por lemon_url para que coincida con la nueva lógica
const { id, title, price, img_url, slug, lemon_url = "#", hayStock } = Astro.props;
---

<article class="game-card">
  <a href={`/juegos/${slug}`} class="wiki-link">
    <div class="image-container">
      <img src={img_url} alt={title} class="game-img" loading="lazy" />
    </div>
    <div class="info">
      <h3>{title}</h3>
      <p class="price">${price ? price.toFixed(2) : "0.00"}</p>
    </div>
  </a>

  <div class="actions">
    <a 
      href={hayStock ? lemon_url : "javascript:void(0)"} 
      class={hayStock ? "buy-btn lemonsqueezy-button" : "buy-btn disabled"}
    >
      {hayStock ? "COMPRAR KEY" : "AGOTADO"}
    </a>
  </div>
</article>

<script src="https://app.lemonsqueezy.com/js/lemon.js" defer></script>

<style>
  /* Tu CSS original exacto */
  .game-card {
    background-color: #111821;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 2px solid rgba(124, 77, 255, 0.1); 
    transition: all 0.3s ease;
  }

  .game-card:hover {
    transform: translateY(-8px);
    border-color: #7c4dff; 
    box-shadow: 0 10px 30px rgba(124, 77, 255, 0.3);
  }

  .wiki-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .image-container { 
    width: 100%; 
    aspect-ratio: 2/3; 
    overflow: hidden; 
  }
  
  .game-img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .wiki-link:hover .game-img {
    transform: scale(1.05);
  }

  .info { 
    padding: 1.2rem 1rem; 
    text-align: center; 
  }
  
  h3 { 
    font-size: 1rem; 
    margin: 0; 
    color: white; 
    font-family: 'Inter', sans-serif;
  }

  .price { 
    color: #2de29d; 
    font-size: 1.3rem; 
    font-weight: 800; 
    margin-top: 0.5rem;
  }

  .actions {
    padding: 0 1rem 1.2rem 1rem;
    margin-top: auto;
  }

  .buy-btn {
    display: block;
    background-color: #5e35b1;
    color: white;
    text-decoration: none;
    text-align: center;
    padding: 0.8rem;
    border-radius: 6px;
    font-weight: bold;
    font-size: 0.85rem;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }

  .buy-btn:hover:not(.disabled) {
    background-color: #7c4dff;
    box-shadow: 0 0 15px rgba(124, 77, 255, 0.6);
    transform: scale(1.02);
  }

  .buy-btn.disabled {
    background-color: #242424;
    color: #666;
    cursor: not-allowed;
    border: 1px solid #333;
    box-shadow: none;
    transform: none;
  }

  .buy-btn.disabled:hover {
    background-color: #242424;
    box-shadow: none;
    transform: none;
  }
</style>