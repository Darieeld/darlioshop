---
const { title, price, img_url, slug } = Astro.props;
---

<a href={`/juegos/${slug}`} class="card-link">
  <article class="game-card">
    <div class="image-container">
      <img src={img_url} alt={title} class="game-img" loading="lazy" />
    </div>
    <div class="info">
      <h3>{title}</h3>
      <p class="price">${price ? price.toFixed(2) : "0.00"}</p>
      <button class="buy-btn">COMPRAR KEY</button>
    </div>
  </article>
</a>

<style>
  .card-link { text-decoration: none; color: inherit; display: block; width: 100%; }
  
  .game-card {
    background-color: #111821;
    border: 2px solid transparent;
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .game-card:hover {
    transform: translateY(-10px);
    border-color: #7c4dff; 
    box-shadow: 0 10px 20px rgba(124, 77, 255, 0.2);
  }

  .image-container { width: 100%; aspect-ratio: 2/3; overflow: hidden; }
  .game-img { width: 100%; height: 100%; object-fit: cover; image-rendering: pixelated; }

  .info { padding: 1rem; text-align: center; display: flex; flex-direction: column; gap: 0.5rem; }
  
  h3 { 
    font-family: 'Inter', sans-serif; /* Usamos Inter para que se lea bien el título */
    font-size: 1rem; 
    font-weight: 700; 
    color: white;
    margin: 0;
  }

  .price { color: #2de29d; font-size: 1.2rem; font-weight: 800; }

  .buy-btn {
    background-color: #5e35b1;
    color: white;
    border: none;
    padding: 0.5rem;
    border-radius: 4px;
    font-weight: bold;
    font-size: 0.7rem;
    cursor: pointer;
  }
</style>