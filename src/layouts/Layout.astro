---
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	html, body {
		margin: 0;
		padding: 0;
		background: #13151a; /* Fondo oscuro global */
		color: white;
		font-family: system-ui, sans-serif;
	}
</style>
