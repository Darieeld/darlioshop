---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Tienda de videojuegos Darlios" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo-pestaña.png" />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Inter:wght@400;700&display=swap" rel="stylesheet">
		
		</head>
	<body>
		<Navbar />
		
		<main class="container">
			<slot /> 
		</main>

		<footer>
			<p>&copy; 2026 DARLIOS - Gaming Store & Wiki</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--nav-bg: #0f172a; /* Asegúrate de que coincida con tus variables de global.css */
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
		min-height: calc(100vh - 180px); 
	}

	footer {
		text-align: center;
		padding: 3rem 2rem;
		background-color: var(--nav-bg);
		color: rgba(255, 255, 255, 0.4);
		font-size: 0.8rem;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
	}

	h1, h2, h3 {
		font-family: 'Press Start 2P', cursive;
		line-height: 1.5;
	}
</style>